# Скопируй в .env и заполни. Файл .env в git не попадает.

# Строка подключения к базе.
# Локально (по умолчанию) — SQLite, ничего ставить не надо:
DATABASE_URL=sqlite:///./data/magaz.db
# На VPS — PostgreSQL, пример:
# DATABASE_URL=postgresql+psycopg2://magaz:ПАРОЛЬ@localhost:5432/magaz

# Секрет для сессий (смени на длинную случайную строку).
SECRET_KEY=change-me-to-a-long-random-string

# Ключ шифрования токенов площадок (сгенерируется автоматически при первом запуске, если пусто).
FERNET_KEY=

# Пароль для входа в интерфейс склада.
APP_PASSWORD=changeme

# Отдельный пароль для полной очистки каталога (разрушительная операция).
WIPE_PASSWORD=2601

# Пароль для чувствительных разделов: Журнал и Настройки (ключи площадок).
ADMIN_PASSWORD=1908

# Публичный адрес, по которому площадки скачивают фото и Avito забирает XML-фид.
# Если включён туннель (ниже) — он перезапишет это значение выданным https-адресом.
# На проде укажи постоянный https-адрес своего сервера/домена, напр.:
# PUBLIC_BASE_URL=https://magaz.example.ru
PUBLIC_BASE_URL=http://localhost:8000

# Автоматический публичный HTTPS-туннель для фото на площадках (localtunnel через npx).
# Ozon/WB тянут картинки со своей стороны и до localhost не дотянутся — туннель
# при старте даёт ВРЕМЕННЫЙ https-адрес и подставляет его в ссылки на фото.
# Минус временного адреса: он меняется при каждом запуске и иногда отдаёт страницу-
# заглушку вместо картинки — площадки не могут скачать фото. Для стабильной работы
# размести приложение на постоянном хостинге (VPS с публичным доменом), задай
# PUBLIC_BASE_URL выше и поставь TUNNEL_ENABLED=false.
TUNNEL_ENABLED=true
# Порт, на котором работает приложение (куда указывает туннель).
APP_PORT=8000
# Явный путь к npx, если не находится в PATH (обычно оставить пустым).
NPX_PATH=

# Как часто фоново опрашивать заказы площадок, минут (меньше — короче окно двойной продажи).
POLL_INTERVAL_MINUTES=5

# Включить фоновый опрос заказов. В тестах ставим false.
SCHEDULER_ENABLED=true

# Габариты и вес книги по умолчанию (Ozon требует их для карточки). Подставляются,
# если у книги не заданы свои значения. Вес в граммах, размеры в миллиметрах,
# вместе с упаковкой. По умолчанию — типичная книга.
DEFAULT_WEIGHT_GRAMS=300
DEFAULT_LENGTH_MM=220
DEFAULT_WIDTH_MM=150
DEFAULT_HEIGHT_MM=30
