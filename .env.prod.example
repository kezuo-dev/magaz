# Настройки центрального сервера. Скопируйте в .env.prod и заполните.
#   cp .env.prod.example .env.prod
# Файл .env.prod в git не попадает (см. .gitignore) — в нём пароли и ключи.

# --- Домен и HTTPS ---------------------------------------------------------
# Ваш домен (без https://). На него должна быть направлена A-запись → IP сервера.
DOMAIN=magaz.example.ru
# Почта для уведомлений Let's Encrypt о продлении сертификата.
ACME_EMAIL=you@example.ru
# Полный публичный адрес — по нему площадки скачивают фото. Совпадает с доменом.
PUBLIC_BASE_URL=https://magaz.example.ru

# --- База данных PostgreSQL ------------------------------------------------
# Эти значения использует и контейнер базы, и приложение (строку подключения
# docker-compose собирает сам). Пароль смените на длинный случайный.
POSTGRES_DB=magaz
POSTGRES_USER=magaz
POSTGRES_PASSWORD=СМЕНИ-НА-ДЛИННЫЙ-СЛУЧАЙНЫЙ-ПАРОЛЬ

# --- Секреты приложения ----------------------------------------------------
# Секрет сессий — длинная случайная строка (напр. вывод: openssl rand -hex 32).
SECRET_KEY=СМЕНИ-НА-ДЛИННУЮ-СЛУЧАЙНУЮ-СТРОКУ
# Ключ шифрования токенов площадок. Оставьте пустым — сгенерируется при первом
# запуске. ВАЖНО: после первого старта сохраните сгенерированный ключ (см.
# инструкцию), иначе при пересоздании контейнера ключи площадок «протухнут».
FERNET_KEY=

# --- Пароли входа ----------------------------------------------------------
# Пароль для входа в интерфейс склада (знают сотрудники обоих складов).
APP_PASSWORD=СМЕНИ
# Пароль для полной очистки каталога (разрушительная операция).
WIPE_PASSWORD=СМЕНИ
# Пароль для разделов Журнал и Настройки (ключи площадок).
ADMIN_PASSWORD=СМЕНИ

# --- Прочее ----------------------------------------------------------------
# Туннель loca.lt на сервере не нужен (адрес и так публичный).
TUNNEL_ENABLED=false
# Как часто опрашивать заказы площадок, минут.
POLL_INTERVAL_MINUTES=5
SCHEDULER_ENABLED=true

# Габариты и вес книги по умолчанию (Ozon требует их для карточки).
DEFAULT_WEIGHT_GRAMS=300
DEFAULT_LENGTH_MM=220
DEFAULT_WIDTH_MM=150
DEFAULT_HEIGHT_MM=30
